{
  "name": "arcade-electron",
  "version": "1.0.0",
  "description": "Arcade Electron App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --x64"
  },
  "keywords": [],
  "author": "Chiara Kanya",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "ocs": "^1.1.0",
    "osc": "^2.4.5"
  },
  "build": {
    "appId": "com.modelnation.console",
    "productName": "Model Nation",
    "files": [
      "**/*",
      "!dist/**",
      "!out/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}